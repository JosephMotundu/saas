# Copier ce fichier vers .env et ajuster les valeurs. Ne jamais committer .env.

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-en-une-longue-chaine-aleatoire
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Kinshasa

# Base de données PostgreSQL (docker-compose service "db")
DATABASE_URL=postgres://paroisseconnect:paroisseconnect@db:5432/paroisseconnect

POSTGRES_DB=paroisseconnect
POSTGRES_USER=paroisseconnect
POSTGRES_PASSWORD=paroisseconnect

# Géocodage Nominatim (OpenStreetMap) — respecter la politique d'usage (User-Agent identifiable)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=paroisseconnect/1.0 (contact@paroisseconnect.example)

# Production uniquement
DJANGO_SECURE_SSL_REDIRECT=True
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
